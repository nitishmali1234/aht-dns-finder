{
  "name": "aht-query-tool",
  "version": "1.0.0",
  "description": "AHT Query Interface — internal tool for Acquia hosting queries",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac dmg",
    "build:win": "electron-builder --win nsis",
    "build:all": "electron-builder --mac dmg --win nsis"
  },
  "build": {
    "appId": "com.internal.aht-query-tool",
    "productName": "AHT Query Tool",
    "copyright": "Internal tool",
    "files": [
      "main.js",
      "preload.js",
      "assets/**"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!node_modules/.cache/**",
          "!windows-install/**",
          "!launch-agent/**",
          "!dist/**",
          "!STANDALONE-BUILD.md"
        ]
      },
      {
        "from": "../frontend/public",
        "to": "frontend/public"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "icon": "assets/icon.png"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "dmg": {
      "title": "AHT Query Tool",
      "window": { "width": 540, "height": 380 },
      "contents": [
        { "x": 140, "y": 180, "type": "file" },
        { "x": 400, "y": 180, "type": "link", "path": "/Applications" }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "installerIcon": "assets/icon.ico",
      "shortcutName": "AHT Query Tool"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
